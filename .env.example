# Copy this to .env and fill in your values
GEMINI_API_KEY=your_google_ai_studio_key_here
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=youtube_token.json

# ── Playlists — create each on YouTube Studio, then paste the ID (PLxxxxxxx) here
YT_PLAYLIST_MORNING=     # "Morning Raga Rituals"          — Friday + Sunday
YT_PLAYLIST_FOCUS=       # "Focus & Brain Clarity"         — Monday
YT_PLAYLIST_STRESS=      # "Stress & Overthinking Relief"  — Tuesday + Wednesday
YT_PLAYLIST_SLEEP=       # "Sleep & Deep Rest"             — Thursday
YT_PLAYLIST_MIDNIGHT=    # "Midnight Calm"                 — Saturday
